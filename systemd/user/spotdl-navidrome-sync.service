[Unit]
Description=Sync Spotify sources into Navidrome
Documentation=file:/home/aym-n/homelab/README.md

[Service]
Type=oneshot
WorkingDirectory=/home/aym-n/homelab
Environment=SPOTDL_THREADS=3
Environment=SPOTDL_MAX_RETRIES=1
Environment=SPOTDL_GENERATE_LRC=0
Environment=SPOTDL_LYRICS_PROVIDERS=genius
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
MemoryHigh=1G
MemoryMax=1536M
ExecStart=/home/aym-n/homelab/scripts/spotdl-navidrome-sync.sh
